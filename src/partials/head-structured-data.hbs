<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://redpanda.com/#organization",
      "name": "Redpanda Data",
      "url": "https://redpanda.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://redpanda.com/favicon.ico",
        "width": 512,
        "height": 512
      },
      "description": "Redpanda is a streaming data platform and Agentic Data Plane for developers. Build real-time applications without the complexity of legacy platforms.",
      "sameAs": [
        "https://twitter.com/redpandadata",
        "https://www.linkedin.com/company/redpanda-data",
        "https://github.com/redpanda-data",
        "https://www.youtube.com/@RedpandaData",
        "https://bsky.app/profile/redpanda.com"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "Customer Support",
        "url": "https://redpanda.com/contact"
      }
    },
    {
      "@type": "WebSite",
      "@id": "{{#with site.url}}{{{this}}}{{else}}https://docs.redpanda.com{{/with}}/#website",
      "url": "{{#with site.url}}{{{this}}}{{else}}https://docs.redpanda.com{{/with}}",
      "name": "Redpanda Documentation",
      "description": "Redpanda Documentation: Guides, API references, and resources for event streaming and Agentic Data Plane.",
      "publisher": {
        "@id": "https://redpanda.com/#organization"
      },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "{{#with site.url}}{{{this}}}{{else}}https://docs.redpanda.com{{/with}}/search/?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }{{#if page.title}},
    {
      "@type": "TechArticle",
      "@id": "{{#with site.url}}{{{this}}}{{else}}https://docs.redpanda.com{{/with}}{{page.url}}#article",
      "headline": "{{json-safe page.title}}",
      {{#with page.attributes.navtitle}}{{#unless (eq this ../page.title)}}
      "alternativeHeadline": "{{json-safe this}}",
      {{/unless}}{{/with}}
      {{#with page.description}}
      "description": "{{json-safe this}}",
      {{/with}}
      {{#with page.keywords}}
      "keywords": "{{json-safe this}}",
      {{else}}{{#with page.attributes.categories}}
      "keywords": "{{json-safe this}}",
      {{/with}}{{/with}}
      "url": "{{#with site.url}}{{{this}}}{{else}}https://docs.redpanda.com{{/with}}{{page.url}}",
      {{#with page.attributes.git-created-date}}
      "datePublished": "{{this}}",
      {{else}}{{#with page.attributes.release-date}}
      "datePublished": "{{this}}",
      {{/with}}{{/with}}
      {{#with page.attributes.git-modified-date}}
      "dateModified": "{{this}}",
      {{else}}{{#with page.attributes.release-date}}
      "dateModified": "{{this}}",
      {{/with}}{{/with}}
      {{#with page.attributes.topic-type}}
      "learningResourceType": "{{json-safe this}}",
      {{/with}}
      {{#with page.attributes.prerequisites}}
      "dependencies": "{{json-safe this}}",
      {{/with}}
      {{#with (page-attribute "personas")}}
      "audience": {
        "@type": "Audience",
        "audienceType": "{{json-safe this}}"
      },
      {{/with}}
      {{#with (page-attribute "learning-objective-1")}}
      "teaches": "{{json-safe this}}{{#with (page-attribute "learning-objective-2")}}; {{json-safe this}}{{/with}}{{#with (page-attribute "learning-objective-3")}}; {{json-safe this}}{{/with}}",
      {{/with}}
      {{#with page.version}}
      "version": "{{this}}",
      {{/with}}
      {{#with page.module}}
      "articleSection": "{{this}}",
      {{/with}}
      "isAccessibleForFree": true,
      "author": {
        "@id": "https://redpanda.com/#organization"
      },
      "publisher": {
        "@id": "https://redpanda.com/#organization"
      },
      "inLanguage": "en",
      "isPartOf": {
        "@id": "{{#with site.url}}{{{this}}}{{else}}https://docs.redpanda.com{{/with}}/#website"
      }{{#if page.component.title}},
      "about": {
        "@type": "SoftwareApplication",
        "name": "{{json-safe page.component.title}}",
        "applicationCategory": "Agentic Data Plane"
      }{{/if}}
    }{{/if}}{{#if page.attributes.has-faqs}},
    {
      "@type": "FAQPage",
      "mainEntity": [{{#each (obj page.attributes.faqs)}}{{#unless @first}},{{/unless}}
        {
          "@type": "Question",
          "name": "{{json-safe this.question}}"{{#if this.anchor}},
          "url": "{{#with @root.site.url}}{{{this}}}{{else}}https://docs.redpanda.com{{/with}}{{@root.page.url}}{{#unless (starts-with this.anchor '#')}}#{{/unless}}{{this.anchor}}"{{/if}},
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "{{json-safe this.answer}}"
          }
        }{{/each}}
      ]
    }{{/if}}
  ]
}
</script>
