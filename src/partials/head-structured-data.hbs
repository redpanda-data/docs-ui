<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://redpanda.com/#organization",
      "name": "Redpanda Data",
      "url": "https://redpanda.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://redpanda.com/favicon.ico",
        "width": 512,
        "height": 512
      },
      "description": "Redpanda is a streaming data platform and Agentic Data Plane for developers. Build real-time applications without the complexity of legacy platforms.",
      "sameAs": [
        "https://twitter.com/redpandadata",
        "https://www.linkedin.com/company/redpanda-data",
        "https://github.com/redpanda-data",
        "https://www.youtube.com/@RedpandaData",
        "https://bsky.app/profile/redpanda.com"
      ],
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "Customer Support",
        "url": "https://redpanda.com/contact"
      }
    },
    {
      "@type": "WebSite",
      "@id": "{{#with site.url}}{{{this}}}{{else}}https://docs.redpanda.com{{/with}}/#website",
      "url": "{{#with site.url}}{{{this}}}{{else}}https://docs.redpanda.com{{/with}}",
      "name": "Redpanda Documentation",
      "description": "Redpanda Documentation: Guides, API references, and resources for event streaming and Agentic Data Plane.",
      "publisher": {
        "@id": "https://redpanda.com/#organization"
      },
      "potentialAction": {
        "@type": "SearchAction",
        "target": {
          "@type": "EntryPoint",
          "urlTemplate": "{{#with site.url}}{{{this}}}{{else}}https://docs.redpanda.com{{/with}}/search/?q={search_term_string}"
        },
        "query-input": "required name=search_term_string"
      }
    }{{#if page.title}},
    {
      "@type": "TechArticle",
      "@id": "{{#with site.url}}{{{this}}}{{else}}https://docs.redpanda.com{{/with}}{{page.url}}#article",
      "headline": "{{json-safe page.title}}",
      {{#if page.attributes.navtitle}}{{#unless (eq page.attributes.navtitle page.title)}}
      "alternativeHeadline": "{{json-safe page.attributes.navtitle}}",
      {{/unless}}{{/if}}
      {{#if page.attributes.description}}
      "description": "{{json-safe page.attributes.description}}",
      {{/if}}
      {{#if page.attributes.keywords}}
      "keywords": "{{json-safe page.attributes.keywords}}",
      {{else}}{{#if page.attributes.categories}}
      "keywords": "{{json-safe page.attributes.categories}}",
      {{/if}}{{/if}}
      "url": "{{#with site.url}}{{{this}}}{{else}}https://docs.redpanda.com{{/with}}{{page.url}}",
      {{#with (git-created-date)}}
      "datePublished": "{{this}}",
      {{else}}{{#with page.attributes.page-release-date}}
      "datePublished": "{{this}}",
      {{/with}}{{/with}}
      {{#with (git-modified-date)}}
      "dateModified": "{{this}}",
      {{else}}{{#with page.attributes.page-release-date}}
      "dateModified": "{{this}}",
      {{/with}}{{/with}}
      {{#if page.attributes.page-role}}
      "genre": "{{json-safe page.attributes.page-role}}",
      {{/if}}
      {{#if page.attributes.page-prerequisites}}
      "dependencies": "{{json-safe page.attributes.page-prerequisites}}",
      {{/if}}
      "author": {
        "@id": "https://redpanda.com/#organization"
      },
      "publisher": {
        "@id": "https://redpanda.com/#organization"
      },
      "inLanguage": "en",
      "isPartOf": {
        "@id": "{{#with site.url}}{{{this}}}{{else}}https://docs.redpanda.com{{/with}}/#website"
      }{{#if page.component.title}},
      "about": {
        "@type": "SoftwareApplication",
        "name": "{{json-safe page.component.title}}"{{#if page.component.asciidoc.attributes.application-category}},
        "applicationCategory": "{{json-safe page.component.asciidoc.attributes.application-category}}"{{/if}}
      }{{/if}}
    }{{/if}}
  ]
}
</script>
