{{#with page.versions}}
<div class="nav-panel-explore{{#unless @root.page.navigation}} is-active{{/unless}}" data-panel="explore" title="View other versions of Redpanda {{{@root.page.component.title}}}">
  <div class="context">
    <div class="container has-dropdown">
      <span class="current-version">Version {{@root.page.componentVersion.displayVersion}}
        {{#each this as |ver|}}
          {{#if (eq ver.version @root.page.attributes.version)}}
            {{#if (is-eol ver.asciidoc.attributes)}}
              <span class="eol-label">(end of life)</span>
            {{/if}}
          {{/if}}
        {{/each}}
      </span><span class="material-symbols-outlined">
keyboard_arrow_down
</span>
      <div class="versions">
        {{#if (ne @root.page.componentVersion.displayVersion 'default')}}
            {{#each this}}
              {{#if (ne ./version @root.page.version)}}
                {{!-- Skip resolve-resource for absolute URLs --}}
                {{#if (or (starts-with ./url '/') (starts-with ./url 'http'))}}
                  <a class="version{{#if ./missing}} is-missing{{/if}}" href="{{{./url}}}">
                    {{./displayVersion}}
                    {{#if (is-eol ./asciidoc.attributes)}}
                      <span class="eol-label">(end of life)</span>
                    {{/if}}
                  </a>
                {{else}}
                  {{#with (resolve-resource ./url) as |targetPage|}}
                    <a class="version{{#if ../missing}} is-missing{{/if}}" href="{{{relativize ../url}}}">
                      {{../displayVersion}}
                      {{#if (is-eol ../asciidoc.attributes)}}
                        <span class="eol-label">(end of life)</span>
                      {{/if}}
                    </a>
                  {{/with}}
                {{/if}}
              {{/if}}
            {{/each}}
        {{/if}}
      </div>
    </div>
  </div>
</div>
{{/with}}
