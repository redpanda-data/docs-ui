{{!-- Skip pagination for home page and when explicitly disabled --}}
{{#unless (or (eq page.attributes.role 'home') (eq page.attributes.pagination undefined))}}
{{#if (or page.previous page.next)}}
<nav class="pagination">
  {{#with page.previous}}
  <span class="prev"><a href="{{{relativize ./url}}}">{{{./content}}}</a></span>
  {{/with}}
  {{#with page.next}}
  <span class="next"><a href="{{{relativize ./url}}}">{{{./content}}}</a></span>
  {{/with}}
</nav>
{{/if}}
{{/unless}}
