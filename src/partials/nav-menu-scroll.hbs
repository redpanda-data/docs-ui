<div class="nav-panel-menu is-active" data-panel="menu">
  <nav class="nav-menu">
    <!-- DEBUG: page.component.name = "{{page.component.name}}", has-custom-nav = "{{page.attributes.has-custom-nav}}" -->
{{#if page.attributes.has-custom-nav}}
    {{!-- Config-driven navigation from page-navigation attribute --}}
    {{!-- Show home component's own navigation before buckets --}}
    {{#if (eq page.component.name 'home')}}
      <!-- DEBUG: Is home component, checking for navigation -->
      {{#with (get-component-navigation site 'home')}}
        <!-- DEBUG: Found home navigation, rendering nav-tree -->
        {{> nav-tree navigation=this}}
      {{else}}
        <!-- DEBUG: No home navigation found -->
      {{/with}}
    {{else}}
      <!-- DEBUG: Not home component, component is: {{page.component.name}} -->
    {{/if}}
    {{!-- Then show child component buckets --}}
    {{#each (parse-json page.attributes.custom-navigation)}}
      {{> nav-bucket-recursive bucket=this}}
    {{/each}}
{{else if (or (eq page.layout 'lab') (eq page.layout 'labs-search'))}}
{{> nav-tree-lab}}
{{else}}
    {{!-- Standard Antora navigation --}}
{{> nav-tree navigation=page.navigation}}
{{/if}}
  </nav>
</div>
