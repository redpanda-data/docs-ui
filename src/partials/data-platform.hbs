              {{page.attributes.component-3-name}}
              {{#if (or page.attributes.component-3-is-new (ne page.attributes.component-3-deployments 'all'))}}
              <span class="dp-component-badges">
                {{#if page.attributes.component-3-is-new}}
                <span class="dp-component-badge dp-component-badge--new">NEW</span>
                {{/if}}
                {{#if (eq page.attributes.component-3-deployments 'byoc')}}
                <span class="dp-component-badge dp-component-badge--byoc">Cloud BYOC</span>
                {{/if}}
              </span>
              {{/if}}
            </h3>
            <p class="dp-product-tagline">{{page.attributes.component-3-desc}}</p>
          </div>
        </div>
        {{#if page.attributes.component-3-features}}
        <ul class="dp-product-features">
          {{#each (split page.attributes.component-3-features ';;')}}
          <li>{{this}}</li>
          {{/each}}
