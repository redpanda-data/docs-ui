<script>
  document.addEventListener('DOMContentLoaded', function() {
    var form = document.getElementById('dp-ask-form');
    var input = document.getElementById('dp-ask-input');

    if (form && input) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var query = input.value.trim();
        if (typeof window.openChatWithQuery === 'function') {
          window.openChatWithQuery(query, true);
        } else if (typeof window.openChatPanel === 'function') {
          window.openChatPanel();
        }
        input.value = '';
      });
    }

    var chips = document.querySelectorAll('.dp-hero-ask-chip');
    chips.forEach(function(chip) {
      chip.addEventListener('click', function() {
        var suggestion = chip.dataset.suggestion;
        if (typeof window.openChatWithQuery === 'function') {
          window.openChatWithQuery(suggestion, true);
        }
      });
    });
  });
</script>
