{{!-- Data Platform Landing Page
     This serves as the umbrella landing for Self-managed, Cloud, and Connect docs.
     --}}
<div class="dp-page">
  <header class="dp-hero">
    <div class="dp-hero-bg" aria-hidden="true">
      <div class="dp-hero-glow dp-hero-glow-1"></div>
      <div class="dp-hero-glow dp-hero-glow-2"></div>
      <div class="dp-hero-grid"></div>
    </div>
    <div class="dp-hero-inner">
      <div class="dp-hero-eyebrow">
        <span>REDPANDA DATA PLATFORM</span>
      </div>
      <h1 class="dp-hero-title">
        The streaming foundation<br>
        for everything you build.
      </h1>
      <p class="dp-hero-sub">
        Run Redpanda on your infrastructure or let us manage it in the cloud.
        Then connect it to everything else with declarative pipelines.
      </p>

      {{!-- Opens chat drawer on submit --}}
      <form class="dp-hero-ask" id="dp-ask-form">
        <span class="dp-hero-ask-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3l2.5 5.5L20 11l-5.5 2.5L12 19l-2.5-5.5L4 11l5.5-2.5z"/>
            <path d="M5 3v4M3 5h4M19 17v4M17 19h4"/>
          </svg>
        </span>
        <input
          type="text"
          class="dp-hero-ask-input"
          id="dp-ask-input"
          placeholder="{{#if page.attributes.hero-ask-placeholder}}{{page.attributes.hero-ask-placeholder}}{{else}}Ask AI about Redpanda...{{/if}}"
          autocomplete="off"
        >
        <button type="submit" class="dp-hero-ask-submit" aria-label="Ask">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </button>
      </form>

      {{#if page.attributes.hero-suggestion-1}}
      <div class="dp-hero-ask-hints">
        <span class="dp-hero-ask-hints-label">{{#if page.attributes.hero-suggestions-label}}{{page.attributes.hero-suggestions-label}}{{else}}Try asking:{{/if}}</span>
        <button type="button" class="dp-hero-ask-chip" data-suggestion="{{page.attributes.hero-suggestion-1}}">{{page.attributes.hero-suggestion-1}}</button>
        {{#if page.attributes.hero-suggestion-2}}
        <button type="button" class="dp-hero-ask-chip" data-suggestion="{{page.attributes.hero-suggestion-2}}">{{page.attributes.hero-suggestion-2}}</button>
        {{/if}}
        {{#if page.attributes.hero-suggestion-3}}
        <button type="button" class="dp-hero-ask-chip" data-suggestion="{{page.attributes.hero-suggestion-3}}">{{page.attributes.hero-suggestion-3}}</button>
        {{/if}}
      </div>
      {{/if}}

      <div class="dp-hero-stats">
        <div><strong>10x</strong><span>faster than Kafka, same wire</span></div>
        <div><strong>{{page.attributes.hero-stat2-number}}</strong><span>connectors</span></div>
      </div>
    </div>
  </header>

  {{!-- Cloud landing: component cards --}}
  {{#if page.attributes.page-cloud-landing}}
  <section class="dp-section dp-component-cards-section">
    <div class="dp-section-head">
      <h2 class="dp-section-title">{{#if page.attributes.component-cards-title}}{{page.attributes.component-cards-title}}{{else}}Choose your component{{/if}}</h2>
    </div>
    <div class="dp-products">

      {{#if page.attributes.component-1-name}}
      <a href="{{{relativize (resolve-resource page.attributes.component-1-link)}}}"
         class="dp-product"
         style="--dp-accent: {{or (get-component-color site (get-component-from-resource page.attributes.component-1-link)) '#1f5bd6'}}">
        <div class="dp-product-head">
          <div class="dp-product-titles">
            <h3 class="dp-product-name">
              {{page.attributes.component-1-name}}
              {{#if (or page.attributes.component-1-is-new (ne page.attributes.component-1-deployments 'all'))}}
              <span class="dp-component-badges">
                {{#if page.attributes.component-1-is-new}}
                <span class="dp-component-badge dp-component-badge--new">NEW</span>
                {{/if}}
                {{#if (eq page.attributes.component-1-deployments 'byoc')}}
                <span class="dp-component-badge dp-component-badge--byoc">Cloud BYOC</span>
                {{/if}}
              </span>
              {{/if}}
            </h3>
            <p class="dp-product-tagline">{{page.attributes.component-1-desc}}</p>
          </div>
        </div>
        {{#if page.attributes.component-1-features}}
        <ul class="dp-product-features">
          {{#each (split page.attributes.component-1-features ';;')}}
          <li>{{this}}</li>
          {{/each}}
        </ul>
        {{/if}}
        <div class="dp-product-cta">
          <span>{{#if page.attributes.component-1-cta-text}}{{page.attributes.component-1-cta-text}}{{else}}Open docs{{/if}}</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </a>
      {{/if}}

      {{#if page.attributes.component-2-name}}
      <a href="{{{relativize (resolve-resource page.attributes.component-2-link)}}}"
         class="dp-product"
         style="--dp-accent: {{or (get-component-color site (get-component-from-resource page.attributes.component-2-link)) '#1f5bd6'}}">
        <div class="dp-product-head">
          <div class="dp-product-titles">
            <h3 class="dp-product-name">
              {{page.attributes.component-2-name}}
              {{#if (or page.attributes.component-2-is-new (ne page.attributes.component-2-deployments 'all'))}}
