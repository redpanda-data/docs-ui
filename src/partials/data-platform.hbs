      {{/if}}

      {{#if page.attributes.component-3-name}}
      <a href="{{{relativize (resolve-resource page.attributes.component-3-link)}}}"
         class="dp-product"
         style="--dp-accent: {{or (get-component-color site (get-component-from-resource page.attributes.component-3-link)) '#1f5bd6'}}">
