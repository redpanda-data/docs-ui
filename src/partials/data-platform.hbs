        {{/if}}
        <div class="dp-product-cta">
          <span>{{#if page.attributes.component-3-cta-text}}{{page.attributes.component-3-cta-text}}{{else}}Open docs{{/if}}</span>
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
            <path d="M6 12L10 8L6 4" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
      </a>
      {{/if}}

    </div>
  </section>

  {{!-- Cloud landing: deployment options --}}
  <section class="dp-section dp-deployment-section">
    <div class="dp-section-head">
      <h2 class="dp-section-title">{{#if page.attributes.deployment-cards-title}}{{page.attributes.deployment-cards-title}}{{else}}Choose your deployment{{/if}}</h2>
    </div>
    <div class="dp-deployment-cards">

      {{#if page.attributes.deployment-1-name}}
