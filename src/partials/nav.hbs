{{#if (ne page.layout '404') }}
{{> feedback-forms}}
{{/if}}
<div class="nav-container"{{#if page.component}} data-component="{{page.component.name}}" data-version="{{page.version}}"{{/if}}>
  <aside class="nav sidebar">
    {{!-- Sidebar Header: Logo + Branding --}}
    <div class="sb-head">
      {{#with site.homeUrl}}
      <a class="sb-head-link" href="{{{relativize this}}}" aria-label="Go to home page">
        <div class="sb-logomark">
          <img src="{{{@root.uiRootPath}}}/img/footer-logo.svg" width="28" height="24" alt="Redpanda" />
        </div>
        <div class="sb-brand">
          <div class="sb-brand-title">Redpanda</div>
          <div class="sb-brand-sub">Documentation</div>
        </div>
      </a>
      {{/with}}
    </div>

    {{!-- Search Bar (triggers Algolia) --}}
    <div class="sb-search" data-action="open-search" role="button" tabindex="0" aria-label="Search docs">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="11" cy="11" r="8"></circle>
        <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
      </svg>
      <span class="sb-search-text">Search docs</span>
    </div>

    {{!-- Product Switcher - outside scroll area so dropdown isn't clipped --}}
    {{> product-switcher}}

    {{!-- Navigation content with scrolling --}}
    <div class="sb-scroll">
      {{> nav-menu-scroll}}
    </div>

    {{!-- Status indicator (Cloud docs only) --}}
    {{#if (eq page.component.name 'cloud-data-platform')}}
    {{> status-footer}}
    {{/if}}

    {{!-- Sidebar Footer: Theme toggle + Collapse --}}
    <div class="sb-footer">
      <button class="sb-theme-toggle" id="sidebar-theme-toggle" type="button" title="Toggle light/dark mode" aria-label="Toggle light/dark mode">
        <svg class="sb-theme-icon sb-theme-icon--sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="5"></circle>
          <line x1="12" y1="1" x2="12" y2="3"></line>
          <line x1="12" y1="21" x2="12" y2="23"></line>
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
          <line x1="1" y1="12" x2="3" y2="12"></line>
          <line x1="21" y1="12" x2="23" y2="12"></line>
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
        </svg>
        <svg class="sb-theme-icon sb-theme-icon--moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>
      <button class="sb-collapse-toggle nav-collapse" type="button" title="Collapse sidebar" aria-label="Collapse sidebar">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
          <line x1="9" y1="3" x2="9" y2="21"></line>
          <polyline points="14 9 11 12 14 15"></polyline>
        </svg>
      </button>
    </div>
  </aside>
</div>
{{> nav-expand}}
