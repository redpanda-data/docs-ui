{{!--
  Recursive bucket rendering for unified navigation
  Supports nested bucket structures (parent buckets containing child buckets)

  On umbrella page: ALL buckets render with headers (including parents)
  On nested pages: Parent buckets unpack (show nav items + children without header)
  showNavItemsOnly: Render nav items without bucket header (for parent context on child pages)
--}}
{{#if bucket.showNavItemsOnly}}
  {{!-- Parent context on child page: show nav items without bucket wrapper --}}
  {{#if bucket.items}}
    <div class="nav-parent-context" data-parent="{{bucket.componentName}}">
      {{> nav-tree navigation=bucket.items}}
    </div>
  {{/if}}
{{else if bucket.children}}
  {{#if (eq @root.page.attributes.is-umbrella-nav "true")}}
    {{!-- Umbrella page: parent renders as a bucket with header, nav items and child buckets at same level --}}
    <div class="nav-bucket nav-bucket-parent" data-bucket="{{bucket.componentName}}" style="--bucket-color: {{bucket.color}};">
      {{> bucket-header bucket=bucket}}
      <div class="nav-bucket-content{{#unless (or bucket.isCurrentBucket bucket.hasCurrentChild bucket.isExpandedByDefault)}} is-collapsed{{/unless}}" id="nav-bucket-{{bucket.componentName}}">
        {{!-- Show parent's nav items if they exist (nav-tree handles nested structures) --}}
        {{#if bucket.items.length}}
          {{> nav-tree navigation=bucket.items}}
        {{/if}}
        {{!-- Child buckets appear nested inside parent --}}
        {{#each bucket.children}}
          {{> nav-bucket-recursive bucket=this}}
        {{/each}}
      </div>
    </div>
  {{else}}
    {{!-- Nested page: parent unpacks completely - NO bucket header, just nav items + child buckets at top level --}}
    {{#if bucket.items}}
      {{> nav-tree navigation=bucket.items}}
    {{/if}}
    {{!-- Child buckets render as normal buckets at same level --}}
    {{#each bucket.children}}
      {{> nav-bucket-recursive bucket=this}}
    {{/each}}
  {{/if}}
{{else}}
  {{!-- Leaf bucket: always render with bucket header --}}
  {{!-- Check if bucket has trivial navigation (0 items, or 1 item with no children) --}}
  {{#if (or (not bucket.items) (and (eq bucket.items.length 1) (not bucket.items.0.items)))}}
    {{!-- Single childless nav item or no items: bucket header is sufficient, hide expand/content --}}
    <div class="nav-bucket nav-bucket--link-only" data-bucket="{{bucket.componentName}}" style="--bucket-color: {{bucket.color}};">
      {{> bucket-header bucket=bucket}}
    </div>
  {{else}}
    {{!-- Multiple nav items: show expandable bucket --}}
    <div class="nav-bucket" data-bucket="{{bucket.componentName}}" style="--bucket-color: {{bucket.color}};">
      {{> bucket-header bucket=bucket}}
      <div class="nav-bucket-content{{#unless (or bucket.isCurrentBucket bucket.isExpandedByDefault)}} is-collapsed{{/unless}}" id="nav-bucket-{{bucket.componentName}}">
        {{> nav-tree navigation=bucket.items}}
      </div>
    </div>
  {{/if}}
{{/if}}
