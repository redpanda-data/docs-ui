<article class="doc {{#if page.attributes.no-toc}}no-toc{{/if}}">
{{#if (and (ne page.attributes.role 'home') (ne page.attributes.role 'component-home-v3'))}}
{{> breadcrumbs}}
{{/if}}
{{#unless page.attributes.cloud}}
{{> latest-banner}}
{{/unless}}
{{#if (eq page.attributes.role 'bloblang-playground')}}
{{> bloblang-signup-form}}
{{/if}}
{{#if (eq page.attributes.role 'home')}}
  {{> home}}
  {{page.contents}}
{{else if (eq page.attributes.role 'component-home-v3')}}
  {{!-- component-home-v3 renders its own title in the hero section --}}
{{else}}
  {{!-- Component indicator pill, version selector, and status badges - sticky header --}}
  <div class="component-indicator-sticky">
    {{#with (get-header-data page)}}
    <div class="component-indicator">
      <span class="component-indicator-pill" style="background: var(--component-color, #6366f1);">
        {{#if this.title}}{{{this.title}}}{{else}}{{@root.page.component.title}}{{/if}}
      </span>
    </div>
    {{/with}}
    {{> version-selector}}
    {{!-- Status badges: Beta, Limited Availability --}}
    {{#if page.attributes.beta}}
    <span class="status-badge status-badge--beta" {{#if page.attributes.beta-text}}data-tippy-content="{{page.attributes.beta-text}}"{{/if}}>
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>
      </svg>
      Beta
    </span>
    {{/if}}
    {{#if page.attributes.limited-availability}}
    <span class="status-badge status-badge--la" {{#if page.attributes.limited-availability-text}}data-tippy-content="{{page.attributes.limited-availability-text}}"{{/if}}>
      <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
      </svg>
      Limited Availability
    </span>
    {{/if}}
  </div>
  {{#with page.title}}
    <h1 class="page">{{{this}}}</h1>
  {{/with}}
{{/if}}
{{#unless (or (eq page.attributes.role 'component-home-v2') (eq page.attributes.role 'component-home-v3'))}}
<div class="metadata metadata--main">
  {{!-- Only show BYOC/Cloud badges on non-ADP pages (ADP uses availability block instead) --}}
  {{#unless page.attributes.adp}}
  {{#if page.attributes.byoc}}
    <div class="byoc-label">
      <p>BYOC</p>
    </div>
  {{/if}}
  {{#if page.attributes.cloud-only}}
    <div class="cloud-label">
      <p>Cloud</p>
    </div>
  {{/if}}
  {{/unless}}
  {{#if page.attributes.context-switcher}}
    {{> context-switcher}}
  {{/if}}
</div>
{{/unless}}
{{!-- Page options dropdown - positioned after preamble via JS --}}
{{#unless (eq page.attributes.role 'component-home-v3')}}
<div class="page-options-container">
  {{> markdown-dropdown}}
</div>
{{/unless}}
{{!-- Availability block for ADP pages showing platform support --}}
{{#if page.attributes.adp}}
{{#unless (eq page.attributes.role 'component-home-v2')}}
{{#unless (eq page.attributes.role 'component-home-v3')}}
{{#unless (eq page.attributes.role 'home')}}
{{#unless (eq page.layout 'index')}}
<div class="availability-block">
  <strong>Available in:</strong>
  {{#if (and page.attributes.byoc page.attributes.cloud-only)}}
    Cloud, BYOC
  {{else if page.attributes.byoc}}
    BYOC
  {{else if page.attributes.cloud-only}}
    Cloud
  {{else}}
    Cloud, BYOC
  {{/if}}
  <span class="availability-info" tabindex="0" aria-label="Availability information">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"></circle>
      <line x1="12" y1="16" x2="12" y2="12"></line>
      <line x1="12" y1="8" x2="12.01" y2="8"></line>
    </svg>
  </span>
</div>
<script>
document.addEventListener("DOMContentLoaded", () => {
  const availabilityInfo = document.querySelector(".availability-info");
  if (availabilityInfo && typeof tippy !== 'undefined') {
    tippy(availabilityInfo, {
      content: "This indicates which Redpanda Cloud cluster types support this feature. Cloud refers to fully managed clusters. BYOC (Bring Your Own Cloud) refers to clusters running in your own cloud account.",
      animation: "scale",
      theme: "redpanda-term",
      touch: "hold",
      interactive: true,
      allowHTML: true,
      appendTo: () => document.body,
      maxWidth: 300
    });
  }
});
</script>
{{/unless}}
{{/unless}}
{{/unless}}
{{/unless}}
{{/if}}
{{#if (or page.attributes.beta page.attributes.limited-availability page.attributes.byoc page.attributes.cloud-only page.attributes.context-switcher)}}
  <script>
  document.addEventListener("DOMContentLoaded", () => {
    const stickyHeader = document.querySelector(".component-indicator-sticky");
    const navMetadataContainer = document.querySelector(".metadata--nav");

    // Initialize tooltips for status badges in sticky header
    const betaBadge = stickyHeader?.querySelector(".status-badge--beta");
    const navBetaBadge = navMetadataContainer?.querySelector(".nav-beta-label");

    if (betaBadge && betaBadge.dataset.tippyContent) {
      tippy(betaBadge, {
        content: betaBadge.dataset.tippyContent,
        animation: "scale",
        theme: "redpanda-term",
        touch: "hold",
        interactive: true,
        allowHTML: true,
        appendTo: () => document.body,
      });
    }
    if (navBetaBadge) {
      tippy(navBetaBadge, {
        content: "{{page.attributes.beta-text}}",
        animation: "scale",
        theme: "redpanda-term",
        touch: "hold",
        interactive: true,
        allowHTML: true,
        appendTo: () => document.body,
      });
    }

    // Initialize tooltips for limited availability badges
    const laBadge = stickyHeader?.querySelector(".status-badge--la");
    const navLimitedAvailabilityBadge = navMetadataContainer?.querySelector(".nav-limited-availability-label");

    if (laBadge && laBadge.dataset.tippyContent) {
      tippy(laBadge, {
        content: laBadge.dataset.tippyContent,
        animation: "scale",
        theme: "redpanda-term",
        touch: "hold",
        interactive: true,
        allowHTML: true,
        appendTo: () => document.body,
      });
    }
    if (navLimitedAvailabilityBadge) {
      tippy(navLimitedAvailabilityBadge, {
        content: "{{page.attributes.limited-availability-text}}",
        animation: "scale",
        theme: "redpanda-term",
        touch: "hold",
        interactive: true,
        allowHTML: true,
        appendTo: () => document.body,
      });
    }

    // Initialize tooltips for BYOC badges if present
    const topByocBadge = metadataContainer.querySelector(".byoc-label p");
    const navByocBadge = navMetadataContainer.querySelector(".nav-byoc-label");
    if (topByocBadge) {
      tippy(topByocBadge, {
        content: "{{page.attributes.byoc-text}}",
        animation: "scale",
        theme: "redpanda-term",
        touch: "hold",
        interactive: true,
        allowHTML: true,
        appendTo: () => document.body,
      });
    }
    if (navByocBadge) {
      tippy(navByocBadge, {
        content: "{{page.attributes.byoc-text}}",
        animation: "scale",
        theme: "redpanda-term",
        touch: "hold",
        interactive: true,
        allowHTML: true,
        appendTo: () => document.body,
      });
    }

    // Initialize tooltips for Cloud badges if present
    const topCloudBadge = metadataContainer.querySelector(".cloud-label p");
    const navCloudBadge = navMetadataContainer.querySelector(".nav-cloud-label");
    if (topCloudBadge) {
      tippy(topCloudBadge, {
        content: "{{page.attributes.cloud-only-text}}",
        animation: "scale",
        theme: "redpanda-term",
        touch: "hold",
        interactive: true,
        allowHTML: true,
        appendTo: () => document.body,
      });
    }
    if (navCloudBadge) {
      tippy(navCloudBadge, {
        content: "{{page.attributes.cloud-only-text}}",
        animation: "scale",
        theme: "redpanda-term",
        touch: "hold",
        interactive: true,
        allowHTML: true,
        appendTo: () => document.body,
      });
    }

    // Show nav metadata when main metadata is not visible
    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navMetadataContainer.classList.add("hidden");
        } else {
          navMetadataContainer.classList.remove("hidden");
        }
      });
    }, {
      root: null,
      threshold: 0.1 // Trigger when 10% of the container is visible
    });

    observer.observe(metadataContainer);
  });
  </script>
{{/if}}
{{#if page.attributes.console-config-migrator}}
{{> console-config-migrator}}
{{/if}}
{{#if (eq page.attributes.role 'component-home')}}
  {{> component-home}}
{{else if (eq page.attributes.role 'component-home-v2')}}
  {{> component-home-v2}}
{{else if (eq page.attributes.role 'component-home-v3')}}
  {{> component-home-v3}}
{{else if (eq page.attributes.role 'bloblang-playground')}}
  {{> bloblang-playground}}
{{else if (eq page.attributes.role 'index-list')}}
  {{> index-list}}
{{else if (eq page.layout 'index')}}
  {{> index}}
{{else if (eq page.attributes.role 'related-labs')}}
  {{#with (list-related-labs page.title page.attributes page.contents)  as |listLabs|}}
    {{{listLabs}}}
  {{/with}}
{{else}}
  {{#with (add-suggested-labs page.attributes page.contents)  as |suggestedLabs|}}
    {{{suggestedLabs}}}
  {{/with}}
{{/if}}
{{#if (and (ne page.attributes.role 'home') (ne page.attributes.role 'component-home-v3'))}}
{{> back-to-top}}
{{/if}}
{{> feedback-footer}}
{{> pagination}}
{{> tracking-pixel}}
</article>
