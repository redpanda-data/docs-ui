{{!--
  Product Switcher - Dropdown for switching between Redpanda product areas
  Shows hierarchical structure with Data Platform containing Streaming + Connect

  Destinations (in order):
    1. ADP → /redpanda-adp/ (Agentic Data Plane)
    2. Data Platform → /data-platform/ (umbrella)
       - Cloud → /cloud-data-platform/
       - Self-Managed → /self-managed/
         - Streaming → /streaming/current/
         - Connect → /connect/

  Expects page-header-data in each component's antora.yml with:
    title, section, description, color, order
--}}
<div class="sb-product-wrap" data-product-switcher>
  {{!-- Current product button --}}
  <button
    class="sb-product-switch"
    data-product-toggle
    aria-haspopup="listbox"
    aria-expanded="false"
    title="Switch product"
    {{#if (eq page.attributes.role 'home')}}style="--component-color: {{get-component-color site 'redpanda-adp'}};"{{else if (or (eq page.component.name 'streaming') (eq page.component.name 'connect') (eq page.component.name 'self-managed') (eq page.component.name 'cloud-data-platform') (eq page.component.name 'data-platform') page.attributes.is-unified-nav)}}style="--component-color: #4338ca;"{{else}}{{#with (get-header-data page)}}{{#if this.color}}style="--component-color: {{this.color}};"{{/if}}{{/with}}{{/if}}
  >
    {{!-- For Labs pages, show "Product Docs" instead of "Labs" --}}
    {{#if (eq page.component.name 'labs')}}
      <span class="sb-product-chip" style="background: var(--component-color, #6366f1);"></span>
      <span class="sb-product-name">View Product Docs</span>
    {{else if (eq page.attributes.role 'home')}}
    {{!-- Home page: show ADP as current product --}}
      <span class="sb-product-chip" style="background: {{get-component-color site 'redpanda-adp'}};"></span>
      <span class="sb-product-name">Agentic Data Plane</span>
    {{else if (eq page.component.name 'cloud-data-platform')}}
    {{!-- Cloud pages: show hierarchy "Data Platform > Cloud" --}}
      <span class="sb-product-chip" style="background: #4338ca;"></span>
      <span class="sb-product-name sb-product-name--hierarchy">
        <span class="sb-product-parent-label">Data Platform</span>
        <span class="sb-product-child-label">Cloud</span>
      </span>
    {{else if (or (eq page.component.name 'streaming') (eq page.component.name 'connect') (eq page.component.name 'self-managed'))}}
    {{!-- Self-Managed pages (Streaming, Connect, Self-Managed home): show hierarchy "Data Platform > Self-Managed" --}}
      <span class="sb-product-chip" style="background: #4338ca;"></span>
      <span class="sb-product-name sb-product-name--hierarchy">
        <span class="sb-product-parent-label">Data Platform</span>
        <span class="sb-product-child-label">Self-Managed</span>
      </span>
    {{else if (or (eq page.component.name 'data-platform') page.attributes.is-unified-nav)}}
    {{!-- Data Platform landing: show "Data Platform" --}}
      <span class="sb-product-chip" style="background: #4338ca;"></span>
      <span class="sb-product-name">Data Platform</span>
    {{else}}
    {{!-- Other components: show their product name --}}
    {{#with page.component}}
      {{#with (get-header-data @root.page)}}
        <span class="sb-product-chip"></span>
        <span class="sb-product-name">
          <span class="sb-product-title">{{#if this.title}}{{{this.title}}}{{else}}{{{../title}}}{{/if}}</span>
        </span>
      {{else}}
        <span class="sb-product-chip"></span>
        <span class="sb-product-name">{{{this.title}}}</span>
      {{/with}}
    {{/with}}
    {{/if}}
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="sb-product-caret">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </button>

  {{!-- Dropdown menu (hidden by default) --}}
  <div class="sb-product-menu" role="listbox" data-product-menu style="display: none;">
    <div class="sb-product-menu-head">Switch product</div>

    {{!-- 1. ADP (Agentic Data Plane) - First --}}
    {{#each site.components}}
      {{#if (eq this.name 'redpanda-adp')}}
        {{#with (get-component-header-data this)}}
    <button
      role="option"
      aria-selected="{{#if (eq ../name @root.page.component.name)}}true{{else}}false{{/if}}"
      class="sb-product-opt {{#if (eq ../name @root.page.component.name)}}is-current{{/if}}"
      data-product-id="{{../name}}"
      data-product-url="{{{relativize ../url}}}"
      style="--product-color: {{#if this.color}}{{this.color}}{{else}}#ea580c{{/if}};"
    >
      <span class="sb-product-chip" style="background: {{#if this.color}}{{this.color}}{{else}}#ea580c{{/if}};"></span>
      <span class="sb-product-opt-text">
        <span class="sb-product-opt-name">Agentic Data Plane</span>
        {{#if this.description}}
        <span class="sb-product-opt-desc">{{{this.description}}}</span>
        {{else}}
        <span class="sb-product-opt-desc">Build AI agents with real-time data</span>
        {{/if}}
      </span>
      {{#if (eq ../name @root.page.component.name)}}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="sb-product-opt-check">
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
      {{/if}}
    </button>
        {{/with}}
      {{/if}}
    {{/each}}

    {{!-- 2. Data Platform (umbrella with Cloud and Self-Managed) --}}
    <div class="sb-product-group">
      <button
        role="option"
        aria-selected="{{#if (eq page.component.name 'data-platform')}}true{{else}}false{{/if}}"
        class="sb-product-opt sb-product-parent {{#if (or (eq page.component.name 'data-platform') (eq page.component.name 'cloud-data-platform') (eq page.component.name 'self-managed') (eq page.component.name 'streaming') (eq page.component.name 'connect'))}}is-current-group{{/if}}"
        data-product-id="data-platform"
        data-product-url="{{{relativize '/data-platform/'}}}"
        style="--product-color: #4338ca;"
      >
        <span class="sb-product-chip" style="background: #4338ca;"></span>
        <span class="sb-product-opt-text">
          <span class="sb-product-opt-name">Data Platform</span>
          <span class="sb-product-opt-desc">Stream, process, and manage your data</span>
        </span>
        {{#if (eq page.component.name 'data-platform')}}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="sb-product-opt-check">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
        {{/if}}
      </button>

      {{!-- Data Platform children: Cloud and Self-Managed --}}
      <div class="sb-product-children">
        {{!-- Cloud --}}
        <button
          role="option"
          aria-selected="{{#if (eq page.component.name 'cloud-data-platform')}}true{{else}}false{{/if}}"
          class="sb-product-opt sb-product-child {{#if (eq page.component.name 'cloud-data-platform')}}is-current{{/if}}"
          data-product-id="cloud-data-platform"
          data-product-url="{{{relativize '/cloud-data-platform/'}}}"
          style="--product-color: #0ea5e9;"
        >
          <span class="sb-product-chip" style="background: #0ea5e9;"></span>
          <span class="sb-product-opt-text">
            <span class="sb-product-opt-name">Cloud</span>
            <span class="sb-product-opt-desc">Fully managed Redpanda</span>
          </span>
          {{#if (eq page.component.name 'cloud-data-platform')}}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="sb-product-opt-check">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          {{/if}}
        </button>

        {{!-- Self-Managed (clickable with nested Streaming and Connect) --}}
        <div class="sb-product-subgroup">
          <button
            role="option"
            aria-selected="{{#if (eq page.component.name 'self-managed')}}true{{else}}false{{/if}}"
            class="sb-product-opt sb-product-child sb-product-subgroup-btn {{#if (or (eq page.component.name 'self-managed') (eq page.component.name 'streaming') (eq page.component.name 'connect'))}}is-current-group{{/if}} {{#if (eq page.component.name 'self-managed')}}is-current{{/if}}"
            data-product-id="self-managed"
            data-product-url="{{{relativize '/self-managed/'}}}"
            style="--product-color: #107569;"
          >
            <span class="sb-product-chip" style="background: #107569;"></span>
            <span class="sb-product-opt-text">
              <span class="sb-product-opt-name">Self-Managed</span>
              <span class="sb-product-opt-desc">Run on your own infrastructure</span>
            </span>
            {{#if (eq page.component.name 'self-managed')}}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="sb-product-opt-check">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            {{/if}}
          </button>
          <div class="sb-product-subgroup-children">
            <button
              role="option"
              aria-selected="{{#if (eq page.component.name 'streaming')}}true{{else}}false{{/if}}"
              class="sb-product-opt sb-product-child sb-product-grandchild {{#if (eq page.component.name 'streaming')}}is-current{{/if}}"
              data-product-id="streaming"
              data-product-url="{{{relativize '/streaming/current/'}}}"
              style="--product-color: #107569;"
            >
              <span class="sb-product-chip" style="background: #107569;"></span>
              <span class="sb-product-opt-text">
                <span class="sb-product-opt-name">Streaming</span>
                <span class="sb-product-opt-desc">Redpanda broker and rpk CLI</span>
              </span>
              {{#if (eq page.component.name 'streaming')}}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="sb-product-opt-check">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              {{/if}}
            </button>

            <button
              role="option"
              aria-selected="{{#if (eq page.component.name 'connect')}}true{{else}}false{{/if}}"
              class="sb-product-opt sb-product-child sb-product-grandchild {{#if (eq page.component.name 'connect')}}is-current{{/if}}"
              data-product-id="connect"
              data-product-url="{{{relativize '/connect/'}}}"
              style="--product-color: #54478C;"
            >
              <span class="sb-product-chip" style="background: #54478C;"></span>
              <span class="sb-product-opt-text">
                <span class="sb-product-opt-name">Connect</span>
                <span class="sb-product-opt-desc">Data pipelines and transformations</span>
              </span>
              {{#if (eq page.component.name 'connect')}}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="sb-product-opt-check">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              {{/if}}
            </button>
          </div>
        </div>
      </div>
    </div>

    {{!-- Footer with Cloud link --}}
    <div class="sb-product-menu-foot">
      <a href="https://cloud.redpanda.com/?utm_source=docs" target="_blank" rel="noopener" class="sb-product-menu-link">
        Open Redpanda Cloud
        <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M7 17L17 7"></path>
          <path d="M7 7h10v10"></path>
        </svg>
      </a>
    </div>
  </div>
</div>
