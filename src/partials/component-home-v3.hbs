{{!--
  Component Home V3 - Landing page with hero, tabs, deploy cards, popular topics, and labs

  Required page attributes:
    :page-role: component-home-v3
    :page-hero-description: Component description text for hero section

  Optional page attributes:
    :page-hero-title: Override for h1 title
    :page-tabs: Get started;;Common workflows;;Reference (tab labels separated by ;;)
    :page-tabs-links: #deploy;;#popular;;#reference (corresponding links, optional)
    :page-tabs-active: 0 (0-indexed active tab, defaults to 0)
    :page-deploy-title: "Deploy Self-Managed Redpanda"
    :page-deploy-1-title: "Docker quickstart"
    :page-deploy-1-desc: "Spin up Redpanda in a container..."
    :page-deploy-1-link: xref:deploy/docker.adoc[]
    :page-deploy-1-time: "5 min"
    :page-deploy-1-icon: package|cloud|terminal
    :page-deploy-2-*, :page-deploy-3-* (same format)
    :page-popular-title: "Popular topics"
    :page-popular-1-title: "What's new"
    :page-popular-1-desc: "Explore new features..."
    :page-popular-1-link: xref:upgrade/whats-new.adoc[]
    :page-popular-1-icon: sparkles|flow|chart|lightning|book|plug
    :page-popular-2-*, :page-popular-3-*, :page-popular-4-* (same format)
    :page-labs-title: "Labs for Self-Managed"
    :page-labs-link: https://redpanda.com/labs
    :page-labs-1-title: "Build a chat room with Rust"
    :page-labs-1-link: https://...
    :page-labs-2-*, :page-labs-3-*, :page-labs-4-* (same format)
--}}
{{!-- Hero Section --}}
<section class="ch3-hero"{{#with (get-header-data page)}}{{#if this.heroGradient}} style="background: {{{this.heroGradient}}};"{{/if}}{{/with}}>
  <div class="ch3-hero-bg" aria-hidden="true">
    <div class="ch3-hero-glow"></div>
    <div class="ch3-hero-grid"></div>
  </div>
  <div class="ch3-hero-inner">
    {{!-- Status chip row --}}
    <div class="ch3-eyebrow-row">
      {{#with (get-header-data page)}}
      {{!-- Status chip: "SELF-MANAGED • v25.1 | GA" format --}}
      <span class="ch3-product-chip">
        {{#if this.eyebrow}}{{{this.eyebrow}}}{{else if this.title}}{{{this.title}}}{{else}}{{@root.page.component.title}}{{/if}}{{#if (and @root.page.versions (gt @root.page.versions.length 1))}}{{#if (ne @root.page.componentVersion.displayVersion 'default')}} • v{{@root.page.componentVersion.displayVersion}}{{/if}}{{/if}}
      </span>
      {{/with}}
      {{#if page.attributes.status-badge}}
      <span class="ch3-ga-badge">{{{page.attributes.status-badge}}}</span>
      {{/if}}
      {{!-- Version selector pill --}}
      {{> version-selector}}
      {{#if page.attributes.beta}}
      <span class="ch3-status-chip beta">Beta</span>
      {{/if}}
    </div>

    {{!-- Main title --}}
    <h1 class="ch3-page-title">
      {{#if page.attributes.hero-title}}
        {{{page.attributes.hero-title}}}
      {{else}}
        {{{page.title}}}
      {{/if}}
    </h1>

    {{!-- Description --}}
    {{#if page.attributes.hero-description}}
    <p class="ch3-page-lede">{{{page.attributes.hero-description}}}</p>
    {{/if}}

    {{!-- Stats bar (optional) --}}
    {{#if page.attributes.stats}}
    <div class="ch3-hero-stats">
      {{#each (split page.attributes.stats ';;')}}
      {{#with (split this '|')}}
      <div class="ch3-hero-stat">
        <strong>{{lookup this 0}}</strong>
        <span>{{lookup this 1}}</span>
      </div>
      {{/with}}
      {{/each}}
    </div>
    {{/if}}
  </div>
</section>

{{!-- Tab Navigation (optional) --}}
{{#if page.attributes.tabs}}
<nav class="ch3-tabs" aria-label="Page sections">
  {{#each (split page.attributes.tabs ';;')}}
  <a class="ch3-tab{{#if (eq @index 0)}} is-active{{/if}}" href="#" data-tab-index="{{@index}}">{{this}}</a>
  {{/each}}
</nav>
{{/if}}

{{!-- Choose Your Path Section (two-column comparison) --}}
{{#if page.attributes.path-title}}
<section class="ch3-path-compare">
  <h2 class="ch3-section-title">{{{page.attributes.path-title}}}</h2>
  <div class="ch3-path-grid">
    {{!-- Self-hosted column --}}
    <div class="ch3-path-col ch3-path-self">
      <div class="ch3-path-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="8" rx="2"/><rect x="2" y="14" width="20" height="8" rx="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/>
        </svg>
      </div>
      <h3 class="ch3-path-heading">{{#if page.attributes.path-self-title}}{{{page.attributes.path-self-title}}}{{else}}Run it yourself{{/if}}</h3>
      <p class="ch3-path-desc">{{#if page.attributes.path-self-desc}}{{{page.attributes.path-self-desc}}}{{else}}Deploy and manage Redpanda on your own infrastructure.{{/if}}</p>
      <ul class="ch3-path-features">
        {{#if page.attributes.path-self-1}}<li>{{{page.attributes.path-self-1}}}</li>{{/if}}
        {{#if page.attributes.path-self-2}}<li>{{{page.attributes.path-self-2}}}</li>{{/if}}
        {{#if page.attributes.path-self-3}}<li>{{{page.attributes.path-self-3}}}</li>{{/if}}
      </ul>
      <a class="ch3-path-cta" href="{{#if page.attributes.path-self-link}}{{{relativize (resolve-resource page.attributes.path-self-link)}}}{{else}}#{{/if}}">
        {{#if page.attributes.path-self-cta}}{{{page.attributes.path-self-cta}}}{{else}}Get started{{/if}}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>

    {{!-- Center divider with "or" --}}
    <div class="ch3-path-divider">
      <div class="ch3-path-or">or</div>
    </div>

    {{!-- Cloud/managed column --}}
    <div class="ch3-path-col ch3-path-cloud">
      <div class="ch3-path-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 10h-1.26A8 8 0 109 20h9a5 5 0 000-10z"/>
        </svg>
      </div>
      <h3 class="ch3-path-heading">{{#if page.attributes.path-cloud-title}}{{{page.attributes.path-cloud-title}}}{{else}}Use Redpanda Cloud{{/if}}</h3>
      <p class="ch3-path-desc">{{#if page.attributes.path-cloud-desc}}{{{page.attributes.path-cloud-desc}}}{{else}}Let us handle the infrastructure so you can focus on your data.{{/if}}</p>
      <ul class="ch3-path-features">
        {{#if page.attributes.path-cloud-1}}<li>{{{page.attributes.path-cloud-1}}}</li>{{/if}}
        {{#if page.attributes.path-cloud-2}}<li>{{{page.attributes.path-cloud-2}}}</li>{{/if}}
        {{#if page.attributes.path-cloud-3}}<li>{{{page.attributes.path-cloud-3}}}</li>{{/if}}
      </ul>
      <a class="ch3-path-cta" href="{{#if page.attributes.path-cloud-link}}{{{relativize (resolve-resource page.attributes.path-cloud-link)}}}{{else}}#{{/if}}">
        {{#if page.attributes.path-cloud-cta}}{{{page.attributes.path-cloud-cta}}}{{else}}Try Redpanda Cloud{{/if}}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    </div>
  </div>
</section>
{{/if}}

