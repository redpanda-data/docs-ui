{{!-- Home Page with Intent-Based Navigation --}}
{{!-- Hero Section with Ask AI Input --}}
<section class="home-hero">
  <div class="home-hero-bg" aria-hidden="true">
    <div class="home-hero-glow home-hero-glow-1"></div>
    <div class="home-hero-glow home-hero-glow-2"></div>
    <div class="home-hero-grid"></div>
  </div>

  <div class="home-hero-inner">
    <div class="home-hero-eyebrow">
      <span class="home-hero-dot"></span>
      {{page.attributes.hero-eyebrow}}
    </div>

    <h1 class="home-hero-title">
      {{{page.attributes.hero-title}}}
    </h1>

    <p class="home-hero-sub">
      {{{page.attributes.hero-subtitle}}}
    </p>

    {{!-- Ask AI Input Form - Opens drawer on submit --}}
    <form class="home-hero-ask" id="home-ask-form">
      <span class="home-hero-ask-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3l2.5 5.5L20 11l-5.5 2.5L12 19l-2.5-5.5L4 11l5.5-2.5z"/>
          <path d="M5 3v4M3 5h4M19 17v4M17 19h4"/>
        </svg>
      </span>
      <input
        type="text"
        class="home-hero-ask-input"
        id="home-ask-input"
        placeholder="{{page.attributes.hero-ask-placeholder}}"
        autocomplete="off"
      >
      <button type="submit" class="home-hero-ask-submit" aria-label="Ask">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </button>
    </form>

    {{!-- Suggestion Chips --}}
    <div class="home-hero-ask-hints">
      <span class="home-hero-ask-hints-label">{{page.attributes.hero-suggestions-label}}</span>
      <button type="button" class="home-hero-chip" data-suggestion="{{page.attributes.hero-suggestion-1}}">{{page.attributes.hero-suggestion-1}}</button>
      <button type="button" class="home-hero-chip" data-suggestion="{{page.attributes.hero-suggestion-2}}">{{page.attributes.hero-suggestion-2}}</button>
      <button type="button" class="home-hero-chip" data-suggestion="{{page.attributes.hero-suggestion-3}}">{{page.attributes.hero-suggestion-3}}</button>
    </div>
  </div>
</section>

{{!-- What Are You Here For Section --}}
<section class="home-intent">
  <div class="home-intent-container">
    <h2 class="home-intent-heading">{{page.attributes.intent-heading}}</h2>

    <div class="home-intent-grid">
      {{!-- Build Agentic Data Flows Card (hide if component doesn't exist) --}}
      {{#if (has-component site 'agentic-data-plane')}}
      <a href="{{{relativize '/agentic-data-plane/'}}}" class="home-intent-card home-intent-card--adp" style="--adp-color: {{get-component-color site 'agentic-data-plane'}};">
        <div class="home-intent-card-icon home-intent-card-icon--brand">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3l2.5 5.5L20 11l-5.5 2.5L12 19l-2.5-5.5L4 11l5.5-2.5z"/>
            <path d="M5 3v4M3 5h4M19 17v4M17 19h4"/>
          </svg>
        </div>
        <div class="home-intent-card-content">
          <h3 class="home-intent-card-title">{{page.attributes.intent-adp-title}}</h3>
          <p class="home-intent-card-desc">{{page.attributes.intent-adp-desc}}</p>
          <div class="home-intent-card-tags">{{page.attributes.intent-adp-tags}}</div>
          <span class="home-intent-card-cta">{{page.attributes.intent-adp-cta}} <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
        </div>
      </a>
      {{/if}}

      {{!-- Stream and Process Data Card --}}
      <a href="{{{relativize '/data-platform/'}}}" class="home-intent-card">
        <div class="home-intent-card-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
          </svg>
        </div>
        <div class="home-intent-card-content">
          <h3 class="home-intent-card-title">{{page.attributes.intent-dp-title}}</h3>
          <p class="home-intent-card-desc">{{page.attributes.intent-dp-desc}}</p>
          <div class="home-intent-card-tags">{{page.attributes.intent-dp-tags}}</div>
          <span class="home-intent-card-cta">{{page.attributes.intent-dp-cta}} <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
        </div>
      </a>
    </div>
  </div>
</section>

{{!-- Jump Straight to a Product Section --}}
<section class="home-products">
  <div class="home-products-container">
    <h2 class="home-products-heading">{{page.attributes.products-heading}}</h2>

    {{!-- Agentic Data Plane (hide section if component doesn't exist) --}}
    {{#if (has-component site 'agentic-data-plane')}}
    <h3 class="home-products-section-heading">{{page.attributes.products-adp-heading}}</h3>
    <div class="home-product-cards">
      {{!-- ADP --}}
      <div class="home-product-card home-product-card--adp" style="--product-color: {{get-component-color site 'agentic-data-plane'}};">
        <div class="home-product-card-content">
          <div class="home-product-card-header">
            <span class="home-product-card-title">{{page.attributes.product-adp-title}}</span>
          </div>
          <p class="home-product-card-desc">{{page.attributes.product-adp-desc}}</p>
          <div class="home-product-card-links">
            <a href="{{#if page.attributes.adp-quickstart}}{{{relativize (resolve-resource page.attributes.adp-quickstart)}}}{{else}}#{{/if}}">{{page.attributes.product-link-get-started}}</a>
            <a href="{{#if page.attributes.adp-docs}}{{{relativize (resolve-resource page.attributes.adp-docs)}}}{{else}}#{{/if}}">{{page.attributes.product-link-docs}}</a>
          </div>
        </div>
      </div>
    </div>
    {{/if}}

    {{!-- Data Platform Products --}}
    <h3 class="home-products-section-heading">{{page.attributes.products-dp-heading}}</h3>
    <div class="home-products-data-platform">
      {{!-- Cloud --}}
      <div class="home-product-group">
        <div class="home-product-card" style="--product-color: {{get-component-color site 'cloud-data-platform'}};">
          <div class="home-product-card-content">
            <div class="home-product-card-header">
              <span class="home-product-card-title">{{page.attributes.product-cloud-title}}</span>
            </div>
            <p class="home-product-card-desc">{{page.attributes.product-cloud-desc}}</p>
            <div class="home-product-card-links">
              <a href="{{#if page.attributes.cloud-quickstart}}{{{relativize (resolve-resource page.attributes.cloud-quickstart)}}}{{else}}#{{/if}}">{{page.attributes.product-link-get-started}}</a>
              <a href="{{#if page.attributes.cloud-docs}}{{{relativize (resolve-resource page.attributes.cloud-docs)}}}{{else}}#{{/if}}">{{page.attributes.product-link-docs}}</a>
            </div>
          </div>
        </div>
      </div>

      {{!-- Self-Managed with nested Streaming and Connect --}}
      <div class="home-product-group home-product-group--with-children">
        <div class="home-product-card home-product-card--parent" style="--product-color: {{get-component-color site 'self-managed'}};">
          <div class="home-product-card-content">
            <div class="home-product-card-header">
              <span class="home-product-card-title">{{page.attributes.product-self-managed-title}}</span>
            </div>
            <p class="home-product-card-desc">{{page.attributes.product-self-managed-desc}}</p>
            <div class="home-product-card-links">
              <a href="{{#if page.attributes.self-managed-docs}}{{{relativize (resolve-resource page.attributes.self-managed-docs)}}}{{else}}#{{/if}}">{{page.attributes.product-link-docs}}</a>
            </div>
          </div>
        </div>

        {{!-- Nested children cards --}}
        <div class="home-product-children">
          {{!-- Streaming --}}
          <div class="home-product-card home-product-card--child" style="--product-color: {{get-component-color site 'streaming'}};">
            <div class="home-product-card-content">
              <div class="home-product-card-header">
                <span class="home-product-card-title">{{page.attributes.product-streaming-title}}</span>
                {{#with site.components.streaming.latest}}<span class="home-product-card-version">v{{version}}</span>{{/with}}
              </div>
              <p class="home-product-card-desc">{{page.attributes.product-streaming-desc}}</p>
              <div class="home-product-card-links">
                <a href="{{#if page.attributes.self-managed-quickstart}}{{{relativize (resolve-resource page.attributes.self-managed-quickstart)}}}{{else}}#{{/if}}">{{page.attributes.product-link-get-started}}</a>
                <a href="{{#if page.attributes.self-managed-docs}}{{{relativize (resolve-resource page.attributes.self-managed-docs)}}}{{else}}#{{/if}}">{{page.attributes.product-link-docs}}</a>
              </div>
            </div>
          </div>

          {{!-- Connect --}}
          <div class="home-product-card home-product-card--child" style="--product-color: {{get-component-color site 'connect'}};">
            <div class="home-product-card-content">
              <div class="home-product-card-header">
                <span class="home-product-card-title">{{page.attributes.product-connect-title}}</span>
              </div>
              <p class="home-product-card-desc">{{page.attributes.product-connect-desc}}</p>
              <div class="home-product-card-links">
                <a href="{{#if page.attributes.connect-quickstart}}{{{relativize (resolve-resource page.attributes.connect-quickstart)}}}{{else}}#{{/if}}">{{page.attributes.product-link-get-started}}</a>
                <a href="{{#if page.attributes.connect-docs}}{{{relativize (resolve-resource page.attributes.connect-docs)}}}{{else}}#{{/if}}">{{page.attributes.product-link-docs}}</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{{!-- Footer --}}
{{> footer}}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var form = document.getElementById('home-ask-form');
    var input = document.getElementById('home-ask-input');

    // Handle form submission - open chat drawer with query
    if (form && input) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var query = input.value.trim();
        if (typeof window.openChatWithQuery === 'function') {
          window.openChatWithQuery(query, true);
        } else if (typeof window.openChatPanel === 'function') {
          window.openChatPanel();
        }
        input.value = '';
      });

      // Also open on focus if input is empty (like prototype behavior)
      input.addEventListener('focus', function() {
        if (!input.value.trim() && typeof window.openChatPanel === 'function') {
          // Optionally open panel on focus - commented out for now
          // window.openChatPanel();
        }
      });
    }

    // Handle suggestion chip clicks
    var chips = document.querySelectorAll('.home-hero-chip');
    chips.forEach(function(chip) {
      chip.addEventListener('click', function() {
        var suggestion = chip.dataset.suggestion;
        if (typeof window.openChatWithQuery === 'function') {
          window.openChatWithQuery(suggestion, true);
        }
      });
    });
  });
</script>
