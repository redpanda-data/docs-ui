{{!-- Home Page with Intent-Based Navigation --}}
{{!-- Hero Section with Ask AI Input --}}
<section class="home-hero">
  <div class="home-hero-bg" aria-hidden="true">
    <div class="home-hero-glow home-hero-glow-1"></div>
    <div class="home-hero-glow home-hero-glow-2"></div>
    <div class="home-hero-grid"></div>
  </div>

  <div class="home-hero-inner">
    <div class="home-hero-eyebrow">
      <span class="home-hero-dot"></span>
      Redpanda Documentation
    </div>

    <h1 class="home-hero-title">
      Everything you need to move data<br>
      and put agents to work on&nbsp;it.
    </h1>

    <p class="home-hero-sub">
      Guides, concepts, and references for the two platforms that power Redpanda &mdash;
      from streaming your data reliably to letting AI agents act on it safely.
    </p>

    {{!-- Ask AI Input Form - Opens drawer on submit --}}
    <form class="home-hero-ask" id="home-ask-form">
      <span class="home-hero-ask-icon" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3l2.5 5.5L20 11l-5.5 2.5L12 19l-2.5-5.5L4 11l5.5-2.5z"/>
          <path d="M5 3v4M3 5h4M19 17v4M17 19h4"/>
        </svg>
      </span>
      <input
        type="text"
        class="home-hero-ask-input"
        id="home-ask-input"
        placeholder="Ask Redpanda AI &mdash; &quot;how do I rotate a key?&quot;, &quot;what is a budget?&quot;"
        autocomplete="off"
      >
      <button type="submit" class="home-hero-ask-submit" aria-label="Ask">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </button>
    </form>

    {{!-- Suggestion Chips --}}
    <div class="home-hero-ask-hints">
      <span class="home-hero-ask-hints-label">Try:</span>
      <button type="button" class="home-hero-chip" data-suggestion="How do I connect Salesforce as an MCP source?">How do I connect Salesforce as an MCP source?</button>
      <button type="button" class="home-hero-chip" data-suggestion="Set a monthly token budget">Set a monthly token budget</button>
      <button type="button" class="home-hero-chip" data-suggestion="Deploy Redpanda on Kubernetes">Deploy Redpanda on Kubernetes</button>
    </div>
  </div>
</section>

{{!-- What Are You Here For Section --}}
<section class="home-intent">
  <div class="home-intent-container">
    <h2 class="home-intent-heading">What are you here for</h2>

    <div class="home-intent-grid">
      {{!-- Stream and Process Data Card --}}
      <a href="{{{relativize '/data-platform/'}}}" class="home-intent-card">
        <div class="home-intent-card-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
          </svg>
        </div>
        <div class="home-intent-card-content">
          <h3 class="home-intent-card-title">Stream and process data</h3>
          <p class="home-intent-card-desc">Run topics, schemas, connectors, and SQL on Cloud or your own infrastructure.</p>
          <div class="home-intent-card-tags">Cloud · Self-Managed · Connect</div>
          <span class="home-intent-card-cta">Get started with Data Platform <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
        </div>
      </a>

      {{!-- Build Agentic Data Flows Card --}}
      <a href="{{{relativize '/redpanda-adp/'}}}" class="home-intent-card home-intent-card--adp" style="--adp-color: {{get-component-color site 'redpanda-adp'}};">
        <div class="home-intent-card-icon home-intent-card-icon--brand">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 3l2.5 5.5L20 11l-5.5 2.5L12 19l-2.5-5.5L4 11l5.5-2.5z"/>
            <path d="M5 3v4M3 5h4M19 17v4M17 19h4"/>
          </svg>
        </div>
        <div class="home-intent-card-content">
          <h3 class="home-intent-card-title">Build agentic data flows</h3>
          <p class="home-intent-card-desc">Compose multi-agent systems on top of your data platform &mdash; tools, memory, observability.</p>
          <div class="home-intent-card-tags">Agentic Data Plane</div>
          <span class="home-intent-card-cta">Get started with ADP <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg></span>
        </div>
      </a>
    </div>
  </div>
</section>

{{!-- Jump Straight to a Product Section --}}
<section class="home-products">
  <div class="home-products-container">
    <h2 class="home-products-heading">Or jump straight to a product</h2>

    {{!-- Data Platform Products --}}
    <h3 class="home-products-section-heading">Data Platform</h3>
    <div class="home-product-cards">
      {{!-- Cloud --}}
      <div class="home-product-card" style="--product-color: {{get-component-color site 'redpanda-cloud'}};">
        <div class="home-product-card-content">
          <div class="home-product-card-header">
            <span class="home-product-card-title">Cloud</span>
          </div>
          <p class="home-product-card-desc">Fully managed Redpanda</p>
          <div class="home-product-card-links">
            <a href="{{#if page.attributes.cloud-quickstart}}{{{relativize (resolve-resource page.attributes.cloud-quickstart)}}}{{else}}#{{/if}}">Get started</a>
            <a href="{{#if page.attributes.cloud-docs}}{{{relativize (resolve-resource page.attributes.cloud-docs)}}}{{else}}#{{/if}}">Docs</a>
          </div>
        </div>
      </div>

      {{!-- Self-Managed --}}
      <div class="home-product-card" style="--product-color: {{get-component-color site 'ROOT'}};">
        <div class="home-product-card-content">
          <div class="home-product-card-header">
            <span class="home-product-card-title">Self-Managed</span>
            {{#with site.components.ROOT.latest}}<span class="home-product-card-version">v{{version}}</span>{{/with}}
          </div>
          <p class="home-product-card-desc">Run on your own infrastructure</p>
          <div class="home-product-card-links">
            <a href="{{#if page.attributes.self-managed-quickstart}}{{{relativize (resolve-resource page.attributes.self-managed-quickstart)}}}{{else}}#{{/if}}">Get started</a>
            <a href="{{#if page.attributes.self-managed-docs}}{{{relativize (resolve-resource page.attributes.self-managed-docs)}}}{{else}}#{{/if}}">Docs</a>
          </div>
        </div>
      </div>

      {{!-- Connect --}}
      <div class="home-product-card" style="--product-color: {{get-component-color site 'redpanda-connect'}};">
        <div class="home-product-card-content">
          <div class="home-product-card-header">
            <span class="home-product-card-title">Connect</span>
          </div>
          <p class="home-product-card-desc">Pipelines and connectors</p>
          <div class="home-product-card-links">
            <a href="{{#if page.attributes.connect-quickstart}}{{{relativize (resolve-resource page.attributes.connect-quickstart)}}}{{else}}#{{/if}}">Get started</a>
            <a href="{{#if page.attributes.connect-docs}}{{{relativize (resolve-resource page.attributes.connect-docs)}}}{{else}}#{{/if}}">Docs</a>
          </div>
        </div>
      </div>
    </div>

    {{!-- Agentic Data Plane --}}
    <h3 class="home-products-section-heading">Agentic Data Plane</h3>
    <div class="home-product-cards">
      {{!-- ADP --}}
      <div class="home-product-card home-product-card--adp" style="--product-color: {{get-component-color site 'redpanda-adp'}};">
        <div class="home-product-card-content">
          <div class="home-product-card-header">
            <span class="home-product-card-title">Agentic Data Plane</span>
          </div>
          <p class="home-product-card-desc">Multi-agent infrastructure</p>
          <div class="home-product-card-links">
            <a href="{{#if page.attributes.adp-quickstart}}{{{relativize (resolve-resource page.attributes.adp-quickstart)}}}{{else}}#{{/if}}">Get started</a>
            <a href="{{#if page.attributes.adp-docs}}{{{relativize (resolve-resource page.attributes.adp-docs)}}}{{else}}#{{/if}}">Docs</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

{{!-- Footer --}}
{{> footer}}

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var form = document.getElementById('home-ask-form');
    var input = document.getElementById('home-ask-input');

    // Handle form submission - open chat drawer with query
    if (form && input) {
      form.addEventListener('submit', function(e) {
        e.preventDefault();
        var query = input.value.trim();
        if (typeof window.openChatWithQuery === 'function') {
          window.openChatWithQuery(query, true);
        } else if (typeof window.openChatPanel === 'function') {
          window.openChatPanel();
        }
        input.value = '';
      });

      // Also open on focus if input is empty (like prototype behavior)
      input.addEventListener('focus', function() {
        if (!input.value.trim() && typeof window.openChatPanel === 'function') {
          // Optionally open panel on focus - commented out for now
          // window.openChatPanel();
        }
      });
    }

    // Handle suggestion chip clicks
    var chips = document.querySelectorAll('.home-hero-chip');
    chips.forEach(function(chip) {
      chip.addEventListener('click', function() {
        var suggestion = chip.dataset.suggestion;
        if (typeof window.openChatWithQuery === 'function') {
          window.openChatWithQuery(suggestion, true);
        }
      });
    });
  });
</script>
